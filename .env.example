# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# IGDB (Twitch) - used by the Supabase Edge Function "igdb-proxy", not the frontend directly
# Set these as secrets on your Supabase project, not here:
#   supabase secrets set TWITCH_CLIENT_ID=xxx TWITCH_CLIENT_SECRET=xxx
